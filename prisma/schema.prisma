datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ─── ENUMS ──────────────────────────────────────────────

enum Role {
  ADMIN
  OPERATIONS_MANAGER
  OFFICE_MANAGER
  SALES_MANAGER
  SHOP_FOREMAN
  DOOR_SHOP
  CREW
}

enum InventoryTier {
  TIER_1
  TIER_2
}

enum POStatus {
  OPEN
  PARTIALLY_RECEIVED
  RECEIVED
  CLOSED
}

enum TransactionType {
  RECEIVE
  CHECKOUT
  ADDITIONAL_PICKUP
  RETURN_FULL
  RETURN_PARTIAL
  RETURN_SCRAP
  CONSUME
  PRODUCE
  SHIP
  ADJUST_UP
  ADJUST_DOWN
}

enum BomStatus {
  DRAFT
  PENDING_REVIEW // Photo-created BOM awaiting owner review
  APPROVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AssemblyType {
  DOOR
  FLOOR_PANEL
  WALL_PANEL
}

enum AssemblyStatus {
  PLANNED
  AWAITING_APPROVAL
  APPROVED
  IN_PRODUCTION
  COMPLETED
  ALLOCATED
  SHIPPED
}

enum ApprovalStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

enum QueueType {
  DOOR_SHOP
  FABRICATION
}

enum NotificationType {
  LOW_STOCK
  BOM_SUBMITTED
  BOM_READY
  DOOR_AWAITING_APPROVAL
  DOOR_APPROVED
  DOOR_REJECTED
  ASSEMBLY_COMPLETED
  REORDER_NEEDED
  CYCLE_COUNT_DUE
  NEEDS_SOURCING
}

enum ProjectedConfidence {
  CONFIRMED
  LIKELY
  POSSIBLE
}

enum JobStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum FabricationSource {
  RSNE_MADE // Fabricated in-house from raw material (e.g., trim cut from coil)
  SUPPLIER  // Ordered pre-fabricated from supplier
}

// ─── MODELS ─────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      Role     @default(CREW)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions    Transaction[]
  bomsCreated     Bom[]               @relation("BomCreator")
  bomsApproved    Bom[]               @relation("BomApprover")
  assemblies      Assembly[]
  cycleCounts     CycleCount[]
  notifications   Notification[]
  doorApprovals   Assembly[]           @relation("DoorApprover")
  assemblyChanges AssemblyChangeLog[]
  projectedJobs   ProjectedJob[]
  matchHistory    MatchHistory[]
}

model Product {
  id            String        @id @default(uuid())
  name          String
  sku           String?       @unique
  category      Category      @relation(fields: [categoryId], references: [id])
  categoryId    String
  tier          InventoryTier @default(TIER_1)
  unitOfMeasure String
  shopUnit      String?
  trackingUnit  String?
  pieceUnit        String?
  dimLength        Decimal?      @db.Decimal(12, 4)
  dimLengthUnit    String?
  dimWidth         Decimal?      @db.Decimal(12, 4)
  dimWidthUnit     String?
  dimThickness     Decimal?      @db.Decimal(12, 4)
  dimThicknessUnit String?
  currentQty    Decimal       @default(0) @db.Decimal(12, 4)
  reorderPoint  Decimal       @default(0) @db.Decimal(12, 4)
  avgCost       Decimal       @default(0) @db.Decimal(12, 4)
  lastCost      Decimal       @default(0) @db.Decimal(12, 4)
  location      String?
  imageUrl      String?
  isActive      Boolean       @default(true)
  notes         String?
  leadTimeDays  Int?
  lastCountedAt DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  transactions               Transaction[]
  bomLineItems               BomLineItem[]
  assemblyComponents         AssemblyComponent[]
  assemblyTemplateComponents AssemblyTemplateComponent[]
  cycleCounts                CycleCount[]
  poLineItems                POLineItem[]
  projectedMaterials         ProjectedMaterial[]
  bomTemplateLineItems       BomTemplateLineItem[]
  fabricationRecipes         FabricationRecipe[] @relation("FinishedProduct")
  usedAsSourceIn             FabricationRecipe[] @relation("SourceProduct")
  matchHistory               MatchHistory[]
  unitConversions            UnitConversion[]
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  color     String?
  sortOrder Int       @default(0)
  products  Product[]
}

model Supplier {
  id          String   @id @default(uuid())
  name        String
  website     String?
  logoUrl     String?
  contactInfo String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  receipts       Receipt[]
  purchaseOrders PurchaseOrder[]
}

model PurchaseOrder {
  id               String   @id @default(uuid())
  poNumber         String   @unique
  supplier         Supplier @relation(fields: [supplierId], references: [id])
  supplierId       String
  status           POStatus @default(OPEN)
  amount           Decimal? @db.Decimal(12, 2)
  jobName          String?
  clientName       String?
  expectedDelivery DateTime?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  lineItems POLineItem[]
  receipts  Receipt[]
}

model POLineItem {
  id              String        @id @default(uuid())
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  purchaseOrderId String
  product         Product?      @relation(fields: [productId], references: [id])
  productId       String?
  description     String        @default("")
  sku             String?
  qtyOrdered      Decimal       @db.Decimal(12, 4)
  qtyReceived     Decimal       @default(0) @db.Decimal(12, 4)
  unitCost        Decimal       @db.Decimal(12, 4)
  createdAt       DateTime      @default(now())
}

model Transaction {
  id              String          @id @default(uuid())
  type            TransactionType
  product         Product         @relation(fields: [productId], references: [id])
  productId       String
  quantity        Decimal         @db.Decimal(12, 4)
  unitCost        Decimal?        @db.Decimal(12, 4)
  totalCost       Decimal?        @db.Decimal(12, 4)
  previousQty     Decimal         @db.Decimal(12, 4)
  newQty          Decimal         @db.Decimal(12, 4)
  previousAvgCost Decimal?        @db.Decimal(12, 4)
  newAvgCost      Decimal?        @db.Decimal(12, 4)
  user            User            @relation(fields: [userId], references: [id])
  userId          String
  notes           String?
  reason          String?
  jobName         String?
  createdAt       DateTime        @default(now())

  bom           Bom?         @relation(fields: [bomId], references: [id])
  bomId         String?
  bomLineItem   BomLineItem? @relation(fields: [bomLineItemId], references: [id])
  bomLineItemId String?
  receipt       Receipt?     @relation(fields: [receiptId], references: [id])
  receiptId     String?
  assembly      Assembly?    @relation(fields: [assemblyId], references: [id])
  assemblyId    String?

  @@index([bomId])
  @@index([bomLineItemId])
  @@index([productId])
  @@index([createdAt])
}

model Bom {
  id           String    @id @default(uuid())
  jobName      String
  jobNumber    String?
  status       BomStatus @default(DRAFT)
  createdBy    User      @relation("BomCreator", fields: [createdById], references: [id])
  createdById  String
  approvedBy   User?     @relation("BomApprover", fields: [approvedById], references: [id])
  approvedById String?
  approvedAt   DateTime?
  jobStartDate DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  lineItems    BomLineItem[]
  transactions Transaction[]
}

model BomLineItem {
  id        String        @id @default(uuid())
  bom       Bom           @relation(fields: [bomId], references: [id], onDelete: Cascade)
  bomId     String
  product   Product?      @relation(fields: [productId], references: [id])
  productId String?
  tier      InventoryTier @default(TIER_1)

  isNonCatalog       Boolean  @default(false)
  nonCatalogName     String?
  nonCatalogCategory String?
  nonCatalogSpecs    Json?
  nonCatalogUom      String?
  nonCatalogEstCost  Decimal? @db.Decimal(12, 4)

  qtyNeeded     Decimal  @db.Decimal(12, 4)
  qtyCheckedOut Decimal  @default(0) @db.Decimal(12, 4)
  qtyReturned   Decimal  @default(0) @db.Decimal(12, 4)
  qtyConsumed   Decimal  @default(0) @db.Decimal(12, 4)
  isAdditional  Boolean  @default(false)
  isActive      Boolean  @default(true)
  pickupDate    DateTime?

  // Fabrication sourcing — null means N/A (not a fabricable item)
  fabricationSource FabricationSource?
  fabricationSpecs  Json?

  // AI matching metadata
  matchConfidence  Float?    // 0-1 AI confidence score for this match
  rawText          String?   // Original text from photo/voice parse
  parsedUom        String?   @db.VarChar(50) // Original AI-parsed unit before conversion (e.g., "case")

  createdAt     DateTime @default(now())

  transactions Transaction[]
  assembly     Assembly? @relation(fields: [assemblyId], references: [id])
  assemblyId   String?

  @@index([bomId])
  @@index([productId])
}

model BomTemplate {
  id          String              @id @default(uuid())
  name        String              @unique
  description String?
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  lineItems BomTemplateLineItem[]
}

model BomTemplateLineItem {
  id                 String        @id @default(uuid())
  template           BomTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId         String
  product            Product?      @relation(fields: [productId], references: [id])
  productId          String?
  tier               InventoryTier @default(TIER_1)
  defaultQty         Decimal       @db.Decimal(12, 4)
  unitOfMeasure      String
  isNonCatalog       Boolean       @default(false)
  nonCatalogName     String?
  nonCatalogCategory String?
  notes              String?
}

model AssemblyTemplate {
  id          String       @id @default(uuid())
  name        String
  type        AssemblyType
  description String?
  specs       Json?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  components AssemblyTemplateComponent[]
  assemblies Assembly[]
}

model AssemblyTemplateComponent {
  id         String           @id @default(uuid())
  template   AssemblyTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId String
  product    Product          @relation(fields: [productId], references: [id])
  productId  String
  qtyPerUnit Decimal          @db.Decimal(12, 4)
  isOptional Boolean          @default(false)
  notes      String?
}

model Assembly {
  id             String            @id @default(uuid())
  template       AssemblyTemplate? @relation(fields: [templateId], references: [id])
  templateId     String?
  type           AssemblyType
  status         AssemblyStatus    @default(PLANNED)
  specs          Json?
  batchSize      Int               @default(1)
  jobName        String?
  jobNumber      String?
  priority       Int               @default(0)
  queueType      QueueType
  cost           Decimal?          @db.Decimal(12, 4)

  producedBy   User   @relation(fields: [producedById], references: [id])
  producedById String
  startedAt    DateTime?
  completedAt  DateTime?
  shippedAt    DateTime?

  approvalStatus ApprovalStatus @default(NOT_REQUIRED)
  approvedBy     User?          @relation("DoorApprover", fields: [approvedById], references: [id])
  approvedById   String?
  approvedAt     DateTime?
  approvalNotes  String?

  notes        String?
  isCustomBuild Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  components   AssemblyComponent[]
  transactions Transaction[]
  bomLineItems BomLineItem[]
  changeLog    AssemblyChangeLog[]
}

model AssemblyComponent {
  id         String   @id @default(uuid())
  assembly   Assembly @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  assemblyId String
  product    Product  @relation(fields: [productId], references: [id])
  productId  String
  qtyUsed    Decimal  @db.Decimal(12, 4)
  unitCost   Decimal  @db.Decimal(12, 4)
  totalCost  Decimal  @db.Decimal(12, 4)
}

model AssemblyChangeLog {
  id          String   @id @default(uuid())
  assembly    Assembly @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  assemblyId  String
  fieldName   String
  oldValue    String?
  newValue    String
  changedBy   User     @relation(fields: [changedById], references: [id])
  changedById String
  reason      String?
  createdAt   DateTime @default(now())
}

model Receipt {
  id              String         @id @default(uuid())
  supplier        Supplier       @relation(fields: [supplierId], references: [id])
  supplierId      String
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderId String?
  receivedAt      DateTime       @default(now())
  notes           String?
  createdAt       DateTime       @default(now())

  transactions Transaction[]
}

model CycleCount {
  id          String   @id @default(uuid())
  product     Product  @relation(fields: [productId], references: [id])
  productId   String
  systemQty   Decimal  @db.Decimal(12, 4)
  actualQty   Decimal  @db.Decimal(12, 4)
  variance    Decimal  @db.Decimal(12, 4)
  reason      String?
  countedBy   User     @relation(fields: [countedById], references: [id])
  countedById String
  countedAt   DateTime @default(now())
}

model ProjectedJob {
  id              String              @id @default(uuid())
  jobName         String
  jobNumber       String?
  confidence      ProjectedConfidence @default(LIKELY)
  expectedStart   DateTime?
  notes           String?
  createdBy       User                @relation(fields: [createdById], references: [id])
  createdById     String
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  materialEstimates ProjectedMaterial[]
}

model ProjectedMaterial {
  id             String       @id @default(uuid())
  projectedJob   ProjectedJob @relation(fields: [projectedJobId], references: [id], onDelete: Cascade)
  projectedJobId String
  product        Product      @relation(fields: [productId], references: [id])
  productId      String
  estimatedQty   Decimal      @db.Decimal(12, 4)
  notes          String?
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  user      User             @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime         @default(now())
}

model Job {
  id             String    @id @default(uuid())
  name           String
  number         String?   @unique
  status         JobStatus @default(ACTIVE)
  client         String?
  contactName    String?
  address        String?
  city           String?
  contractNumber String?
  gcRef          String?
  contractValue  Decimal?  @db.Decimal(12, 2)
  services       String?
  proposalDate   DateTime?
  estStartDate   DateTime?
  estEndDate     DateTime?
  percentBilled  Decimal?  @db.Decimal(5, 2)
  salesLead      String?
  projectManager String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ─── FABRICATION RECIPES ────────────────────────────────
// Defines how finished products (e.g., TWS trim) are made from raw materials (e.g., steel coil)

model FabricationRecipe {
  id                String  @id @default(uuid())
  finishedProduct   Product @relation("FinishedProduct", fields: [finishedProductId], references: [id])
  finishedProductId String
  sourceProduct     Product @relation("SourceProduct", fields: [sourceProductId], references: [id])
  sourceProductId   String

  // How much source material per unit of finished product
  // e.g., 1 piece of TWS IC 2"x2" 8' = 2.67 sq ft of coil
  sourceQtyPerUnit Decimal? @db.Decimal(12, 4)
  sourceUom        String   // "sq ft", "linear ft", etc.

  // For custom-sizable items (Custom TWS, Flatstock)
  isCustomSizable Boolean @default(false)
  fabricationType String? // "STANDARD_TWS" | "CUSTOM_TWS" | "FLATSTOCK"

  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([finishedProductId, sourceProductId])
}

// ─── MATCH HISTORY (Learning Loop) ──────────────────────
// Stores confirmed AI matches so the system learns user shorthand over time

model MatchHistory {
  id             String   @id @default(uuid())
  rawText        String   // Original text from photo/voice ("OC 2x3")
  normalizedText String   // Lowercase, trimmed, collapsed spaces
  product        Product? @relation(fields: [productId], references: [id])
  productId      String?  // Set for catalog matches; null for custom items
  customName     String?  // Set for custom/non-catalog items; null for catalog matches
  // Invariant: exactly one of productId or customName must be set
  user           User     @relation(fields: [userId], references: [id])
  userId         String
  confirmed      Boolean  @default(false)
  usageCount     Int      @default(1)
  lastUsedAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([normalizedText, userId])
  @@index([userId, normalizedText])
  @@index([productId])
}

// ─── UNIT CONVERSIONS (Learning System) ────────────────
// Stores product-specific and global unit conversion factors
// e.g., "FROTH-PAK: 1 case = 12 each" or globally "1 case = 12 each"

model UnitConversion {
  id        String   @id @default(uuid()) @db.Uuid
  product   Product? @relation(fields: [productId], references: [id])
  productId String?
  fromUnit  String   @db.VarChar(30) // "case", "box", "pallet", "lb"
  toUnit    String   @db.VarChar(30) // "each", "linear ft", etc.
  factor    Decimal  @db.Decimal(12, 4) // 1 fromUnit = factor × toUnit
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, fromUnit, toUnit])
  @@index([fromUnit, toUnit])
}
